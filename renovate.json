{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "enabled": true,
    "gitAuthor": "renovate <henrywhitaker3+renovate@outlook.com>",
    "semanticCommits": "enabled",
    "labels": ["renovatebot"],
    "semanticCommitScope": "images",
    "dependencyDashboard": true,
    "dependencyDashboardTitle": "Renovate Dashboard",
    "suppressNotifications": ["prIgnoreNotification"],
    "prConcurrentLimit": 0,
    "rebaseWhen": "conflicted",
    "argocd": {
        "managerFilePatterns": ["/argo/cluster/.*\\.app\\.yaml/"]
    },
    "packageRules": [
        {
            "matchManagers": ["kubernetes"],
            "matchDatasources": ["kubernetes-api"],
            "enabled": false
        },
        {
            "matchDatasources": ["docker"],
            "matchUpdateTypes": ["major"],
            "enabled": true
        },
        {
            "matchDatasources": ["docker"],
            "addLabels": ["docker/image"]
        },
        {
            "matchUpdateTypes": ["patch", "pin", "digest"],
            "addLabels": ["dep/patch"],
            "automerge": true,
            "automergeType": "pr",
            "platformAutomerge": true
        },
        {
            "matchUpdateTypes": ["major"],
            "addLabels": ["dep/major"]
        },
        {
            "matchUpdateTypes": ["minor"],
            "addLabels": ["dep/minor"]
        },
        {
            "matchDatasources": ["terraform"],
            "automerge": false
        },
        {
            "matchUpdateTypes": ["minor"],
            "matchPackageNames": [
                "/sonarr/",
                "/radarr/",
                "/prowlarr/",
                "/tautulli/",
                "/plex/",
                "/grimmory/"
            ],
            "automerge": true
        },
        {
            "matchPackageNames": [
                "/k3s/",
                "/netbirdio/",
                "/longhorn/",
                "/cilium/",
                "ghcr.io/immich-app/immich-server",
                "ghcr.io/immich-app/immich-machine-learning",
                "/netbirdio/"
            ],
            "automerge": false
        },
        {
            "versioning": "regex:^(?<major>\\d{1,3})\\.(?<minor>\\d+)\\.(?<patch>\\d+)$",
            "matchPackageNames": ["/linuxserver\\//"]
        }
    ],
    "customManagers": [
        {
            "customType": "regex",
            "description": ["Process custom dependencies"],
            "managerFilePatterns": ["/ansible/.*/.*\\.yaml$/", "/.*.yaml$/"],
            "matchStrings": [
                "# renovate: datasource=(?<datasource>[^\\s]+) depName=(?<depName>[^\\s]+)\\n\\s+- https://raw\\.githubusercontent\\.com/dragonflydb/dragonfly-operator/(?<currentValue>v[^/]+)/manifests/crd\\.yaml",
                "(?m:# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)( repository=(?<registryUrl>\\S+))?\\n.+?: \"?(?<currentValue>\\S+?)\"?$)"
            ],
            "datasourceTemplate": "{{#if datasource}}{{{datasource}}}{{else}}github-releases{{/if}}"
        }
    ]
}
